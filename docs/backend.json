
{
  "entities": {
    "Employee": {
      "title": "Employee",
      "description": "A member of the Callbox Davao team.",
      "type": "object",
      "properties": {
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "position": { "type": "string" },
        "department": { "type": "string" },
        "status": { "type": "string", "enum": ["Active", "On Leave", "Probationary", "Resigned", "End of Contract, Inactive"] },
        "joinDate": { "type": "string", "format": "date" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["firstName", "lastName", "email", "position"]
    },
    "Certificate": {
      "title": "Certificate",
      "description": "A generated HR document narrative.",
      "type": "object",
      "properties": {
        "employeeName": { "type": "string" },
        "position": { "type": "string" },
        "certificateType": { "type": "string" },
        "startDate": { "type": "string" },
        "endDate": { "type": "string" },
        "employmentStatus": { "type": "string" },
        "purposeOfCertificate": { "type": "string" },
        "narrative": { "type": "string" },
        "status": { "type": "string", "enum": ["Pending", "Approved", "Rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "SystemSettings": {
      "title": "System Settings",
      "description": "Configuration for the FastDocs system.",
      "type": "object",
      "properties": {
        "companyName": { "type": "string" },
        "address": { "type": "string" },
        "hrLead": { "type": "string" },
        "supportEmail": { "type": "string" },
        "autoSaveDrafts": { "type": "boolean" },
        "emailNotifications": { "type": "boolean" },
        "auditTrail": { "type": "boolean" }
      }
    },
    "AdminUser": {
      "title": "Admin User",
      "description": "An administrative user of the FastDocs platform.",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["Admin", "Super Admin"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "role"]
      },
    "Notification": {
      "title": "Notification",
      "description": "A system alert or user notification.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string", "enum": ["Info", "Success", "Warning", "Error"] },
        "isRead": { "type": "boolean" },
        "targetUid": { "type": "string", "description": "The UID of the user this notification is for, or 'global'." },
        "link": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/employees/{employeeId}": {
      "schema": "Employee",
      "description": "Collection of employee records."
    },
    "/certificates/{certificateId}": {
      "schema": "Certificate",
      "description": "Collection of generated certificates."
    },
    "/settings/{settingsId}": {
      "schema": "SystemSettings",
      "description": "Global system settings."
    },
    "/adminUsers/{userId}": {
      "schema": "AdminUser",
      "description": "Collection of platform administrators."
    },
    "/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "Collection of system notifications."
    }
  }
}
